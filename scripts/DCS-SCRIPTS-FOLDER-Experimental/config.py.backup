#!/usr/bin/env python3
"""
config.py - Modern TUI configuration menu for DCS DataPad Server
Features: Grid navigation, command builder, live preview
"""

import json
import os
import sys
import time
import subprocess
from pathlib import Path
from enum import Enum

from enum import Enum

# Windows keyboard support
if os.name == 'nt':
    import msvcrt
else:
    import select
    import tty
    import termios

CONFIG_FILE = "server_config.json"
DEFAULT_CONFIG = {
    "last_mode": 1,
    "ip_address": "192.168.178.100",
    "target_ip": "192.168.178.132",
    "port": 5010,
    "handshake_port": 5011,
    "interval": 10,
    "authorized_devices": "authorized_devices.json",
    "enable_pow": False,
    "pow_difficulty": 16
}

class Key(Enum):
    """Keyboard key codes"""
    UP = 'up'
    DOWN = 'down'
    LEFT = 'left'
    RIGHT = 'right'
    ENTER = 'enter'
    ESC = 'esc'
    BACKSPACE = 'backspace'
    TAB = 'tab'
    CHAR = 'char'
    UNKNOWN = 'unknown'

MODES = {
    1: {
        "name": "ECDH with APP (with PoW protection)",
        "description": "Secure mode with Proof-of-Work DoS protection (adds 50-100ms latency)",
        "command": "python forward_parsed_udp.py --enable-pow --pow-difficulty 16 --interval {interval} --host {target_ip} --port {port} --verbose --authorized-devices {authorized_devices} --bind-ip {ip_address}"
    },
    2: {
        "name": "ECDH with APP (standard)",
        "description": "Secure mode without PoW (faster, but less DoS protection)",
        "command": "python forward_parsed_udp.py --interval {interval} --host {target_ip} --port {port} --verbose --authorized-devices {authorized_devices} --bind-ip {ip_address}"
    },
    3: {
        "name": "Map-Tools Mode",
        "description": "Repeat last data for Map Database Tools (uses separate handshake port)",
        "command": "python forward_parsed_udp.py --repeat-last --interval 500 --host {ip_address} --port {port} --verbose --authorized-devices {authorized_devices} --bind-ip {ip_address} --handshake-port {handshake_port}"
    },
    4: {
        "name": "Custom Mode",
        "description": "Enter custom command line parameters",
        "command": None
    }
}


def load_config():
    """Load configuration from file or return defaults"""
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE, 'r') as f:
                config = json.load(f)
                # Merge with defaults to ensure all keys exist
                return {**DEFAULT_CONFIG, **config}
        except Exception as e:
            print(f"⚠️  Warning: Could not load config ({e}), using defaults")
    return DEFAULT_CONFIG.copy()


def save_config(config):
    """Save configuration to file"""
    try:
        with open(CONFIG_FILE, 'w') as f:
            json.dump(config, f, indent=2)
    except Exception as e:
        print(f"⚠️  Warning: Could not save config ({e})")


def clear_screen():
    """Clear console screen"""
    os.system('cls' if os.name == 'nt' else 'clear')


def get_input_with_timeout(prompt, timeout=3.0, default=None):
    """Get user input with timeout, return default if no input.

    Behavior:
      - If no key is pressed within `timeout` seconds, returns `default`.
      - If any key is pressed during the timeout (Windows only), the timeout is cancelled
        and the function waits indefinitely for the user to finish input (press Enter).
      - On Unix-like systems, terminals are usually line-buffered so a key press will
        only be visible after Enter. We still use select() to detect ready input.
    """
    if os.name == 'nt':  # Windows
        import msvcrt
        print(prompt, end='', flush=True)

        start_time = time.time()
        user_input = ""

        while (time.time() - start_time) < timeout:
            if msvcrt.kbhit():
                # Key pressed -> cancel timeout and switch to blocking read until Enter
                char = msvcrt.getwche()
                if char == '\r':  # Enter key
                    print()
                    return user_input if user_input else default
                elif char == '\x08':  # Backspace
                    if user_input:
                        user_input = user_input[:-1]
                        print('\b \b', end='', flush=True)
                else:
                    user_input += char

                # Now wait (blocking) for the rest of the input until Enter is pressed
                while True:
                    ch = msvcrt.getwche()
                    if ch == '\r':
                        print()
                        return user_input if user_input else default
                    elif ch == '\x08':
                        if user_input:
                            user_input = user_input[:-1]
                            print('\b \b', end='', flush=True)
                    else:
                        user_input += ch
            time.sleep(0.05)

        # Timeout expired without any key press
        print()
        return default
    else:  # Unix-like
        import select
        print(prompt, end='', flush=True)

        ready, _, _ = select.select([sys.stdin], [], [], timeout)
        if ready:
            # If input is ready, read full line (blocking) to allow editing
            return sys.stdin.readline().strip() or default
        print()
        return default


def edit_settings(config):
    """Interactive settings editor"""
    clear_screen()
    print("=" * 70)
    print("  SETTINGS CONFIGURATION")
    print("=" * 70)
    print()
    print("Current settings:")
    print(f"  1. Bind IP Address (Server):    {config['ip_address']}")
    print(f"  2. Target IP Address (Client):  {config['target_ip']}")
    print(f"  3. Data Port:                    {config['port']}")
    print(f"  4. Handshake Port:               {config['handshake_port']}")
    print(f"  5. Update Interval (ms):         {config['interval']}")
    print(f"  6. Authorized Devices File:      {config['authorized_devices']}")
    print()
    print("  0. Back to main menu")
    print()
    
    choice = input("Select setting to change (0-6): ").strip()
    
    if choice == '1':
        new_ip = input(f"Enter new bind IP address [{config['ip_address']}]: ").strip()
        if new_ip:
            config['ip_address'] = new_ip
            print(f"✅ Bind IP updated to: {new_ip}")
    elif choice == '2':
        new_ip = input(f"Enter new target IP address [{config['target_ip']}]: ").strip()
        if new_ip:
            config['target_ip'] = new_ip
            print(f"✅ Target IP updated to: {new_ip}")
    elif choice == '3':
        new_port = input(f"Enter new data port [{config['port']}]: ").strip()
        if new_port.isdigit():
            config['port'] = int(new_port)
            print(f"✅ Port updated to: {new_port}")
    elif choice == '4':
        new_port = input(f"Enter new handshake port [{config['handshake_port']}]: ").strip()
        if new_port.isdigit():
            config['handshake_port'] = int(new_port)
            print(f"✅ Handshake port updated to: {new_port}")
    elif choice == '5':
        new_interval = input(f"Enter new interval in ms [{config['interval']}]: ").strip()
        if new_interval.isdigit():
            config['interval'] = int(new_interval)
            print(f"✅ Interval updated to: {new_interval}ms")
    elif choice == '6':
        new_file = input(f"Enter authorized devices file [{config['authorized_devices']}]: ").strip()
        if new_file:
            config['authorized_devices'] = new_file
            print(f"✅ Authorized devices file updated to: {new_file}")
    elif choice != '0':
        print("❌ Invalid choice")
    
    if choice != '0':
        time.sleep(1.5)
    
    return config


def show_menu(config):
    """Display main menu"""
    clear_screen()
    print("=" * 70)
    print("  DCS DATAPAD SERVER - Configuration Menu")
    print("=" * 70)
    print()
    print(f"Current Settings:")
    print(f"  Bind IP:   {config['ip_address']} | Target IP: {config['target_ip']}")
    print(f"  Port:      {config['port']} | Handshake Port: {config['handshake_port']}")
    print(f"  Interval:  {config['interval']}ms")
    print()
    print("─" * 70)
    print("  SELECT SERVER MODE:")
    print("─" * 70)
    
    for mode_id, mode_info in MODES.items():
        last_used = " ⭐ (Last used)" if mode_id == config['last_mode'] else ""
        print(f"  [{mode_id}] {mode_info['name']}{last_used}")
        print(f"      {mode_info['description']}")
        print()
    
    print("─" * 70)
    print("  [S] Settings (change IP, ports, etc.)")
    print("  [Q] Quit")
    print("─" * 70)
    print()


def build_command(mode_id, config):
    """Build command line for selected mode"""
    if mode_id not in MODES:
        return None
    
    mode = MODES[mode_id]
    if mode['command'] is None:
        # Custom mode
        custom_cmd = input("\nEnter custom command line arguments:\n> ")
        return f"python forward_parsed_udp.py {custom_cmd}"
    
    # Format command with config values
    return mode['command'].format(
        ip_address=config['ip_address'],
        target_ip=config['target_ip'],
        port=config['port'],
        handshake_port=config['handshake_port'],
        interval=config['interval'],
        authorized_devices=config['authorized_devices']
    )


def main():
    """Main application loop"""
    config = load_config()
    
    while True:
        show_menu(config)
        
        last_mode = config['last_mode']
        prompt = f"Select mode [1-4, S, Q] (press any key to cancel auto-select; auto-select [{last_mode}] in 3s): "
        
        choice = get_input_with_timeout(prompt, timeout=3.0, default=str(last_mode))
        
        if choice is None or choice == '':
            choice = str(last_mode)
        
        choice = choice.strip().upper()
        
        if choice == 'Q':
            print("\n👋 Goodbye!")
            save_config(config)
            sys.exit(0)
        elif choice == 'S':
            config = edit_settings(config)
            save_config(config)
            continue
        elif choice.isdigit():
            mode_id = int(choice)
            if mode_id in MODES:
                config['last_mode'] = mode_id
                save_config(config)
                
                command = build_command(mode_id, config)
                if command:
                    print()
                    print("=" * 70)
                    print(f"🚀 Starting: {MODES[mode_id]['name']}")
                    print("=" * 70)
                    print()
                    print(f"Command: {command}")
                    print()
                    print("Press Ctrl+C to stop the server")
                    print("=" * 70)
                    print()
                    time.sleep(1)
                    
                    # Execute command
                    try:
                        subprocess.run(command, shell=True, check=True)
                    except KeyboardInterrupt:
                        print("\n\n⏹️  Server stopped by user")
                        time.sleep(1)
                    except subprocess.CalledProcessError as e:
                        print(f"\n❌ Server exited with error code {e.returncode}")
                        time.sleep(2)
                    
                    # Return to menu after server stops
                    input("\nPress Enter to return to menu...")
            else:
                print(f"\n❌ Invalid mode: {mode_id}")
                time.sleep(1)
        else:
            print(f"\n❌ Invalid choice: {choice}")
            time.sleep(1)


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n👋 Goodbye!")
        sys.exit(0)
    except Exception as e:
        print(f"\n❌ Unexpected error: {e}")
        import traceback
        traceback.print_exc()
        input("\nPress Enter to exit...")
        sys.exit(1)
