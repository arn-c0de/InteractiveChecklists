<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="600"
    android:viewportHeight="600">

    <!-- Background circle (NATO-style marker) -->
    <path
        android:fillColor="#FFFF80"
        android:pathData="M300,50 A250,250 0 1,0 299.999,50 Z"/>

    <!-- Circle frame -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="10"
        android:fillColor="#00000000"
        android:pathData="M300,50 A250,250 0 1,0 299.999,50 Z"/>

    <!-- APC simplified symbol (APP-6 style inspired) -->
    <group android:translateY="140">
        <!-- hull -->
        <path
            android:fillColor="#000000"
            android:pathData="M150,220 h300 v70 h-300 z"/>

        <!-- turret -->
        <path
            android:fillColor="#000000"
            android:pathData="M360,190 h60 v30 h-60 z"/>

        <!-- barrel -->
        <path
            android:strokeColor="#000000"
            android:strokeWidth="8"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M420,205 h60"/>

        <!-- wheels (3) -->
        <path android:fillColor="#000000" android:pathData="M190,300a20,20 0 1,0 40,0a20,20 0 1,0 -40,0"/>
        <path android:fillColor="#000000" android:pathData="M300,300a20,20 0 1,0 40,0a20,20 0 1,0 -40,0"/>
        <path android:fillColor="#000000" android:pathData="M410,300a20,20 0 1,0 40,0a20,20 0 1,0 -40,0"/>
    </group>
</vector>
